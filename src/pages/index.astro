---
// src/pages/index.astro
// Pantalla de selección de idioma — punto de entrada del sitio
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="latama11y — Consultoría de accesibilidad digital para Latinoamérica / Digital accessibility consulting for Latin America" />
  <title>latama11y — Seleccionar idioma / Select language</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --color-bg:       #0a0a0a;
      --color-surface:  #111111;
      --color-border:   #1e1e1e;
      --color-purple:   #7c3aed;
      --color-purple-lt:#a78bfa;
      --color-pink:     #ec4899;
      --color-pink-lt:  #f9a8d4;
      --color-text:     #f4f4f5;
      --color-muted:    #71717a;
      --font-display:   'Syne', sans-serif;
      --font-mono:      'DM Mono', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
    }

    body {
      background-color: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-mono);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem;
      -webkit-font-smoothing: antialiased;
    }

    /* Línea decorativa superior */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--color-purple), var(--color-pink));
    }

    main {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3rem;
      width: 100%;
      max-width: 480px;
      text-align: center;
    }

    .logo {
      font-family: var(--font-display);
      font-size: clamp(2rem, 8vw, 3.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    /* "lata" en blanco, "m" en degradado, "a11y" en blanco */
    .logo .brand-prefix { color: var(--color-text); }
    .logo .brand-m {
      background: linear-gradient(135deg, var(--color-purple-lt), var(--color-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .logo .brand-suffix { color: var(--color-text); }

    .tagline {
      font-size: 0.75rem;
      color: var(--color-muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-top: 0.5rem;
    }

    /* Separador fino */
    .divider {
      width: 100%;
      height: 1px;
      background: #1e1e1e;
    }

    /* Botones de idioma */
    .lang-options {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }

    .lang-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 1.25rem 1.5rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 2px;
      color: var(--color-text);
      font-family: var(--font-mono);
      font-size: 0.9375rem;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.15s ease, background 0.15s ease;
      text-align: left;
    }

    .lang-btn:hover,
    .lang-btn:focus-visible {
      border-color: var(--color-purple-lt);
      background: #16101f;
      text-decoration: none;
      color: var(--color-text);
    }

    .lang-btn:focus-visible {
      outline: 2px solid var(--color-pink);
      outline-offset: 3px;
    }

    .lang-btn__label {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .lang-btn__name {
      font-weight: 500;
      font-size: 1rem;
    }

    .lang-btn__desc {
      font-size: 0.75rem;
      color: var(--color-muted);
    }

    .lang-btn__arrow {
      font-size: 1rem;
      color: var(--color-purple-lt);
      flex-shrink: 0;
      transition: transform 0.15s ease;
    }

    .lang-btn:hover .lang-btn__arrow,
    .lang-btn:focus-visible .lang-btn__arrow {
      transform: translateX(4px);
    }

    /* Animación de entrada */
    @media (prefers-reduced-motion: no-preference) {
      main {
        animation: fadeUp 0.4s ease both;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    }
  </style>
</head>
<body>
  <main>
    <div>
      <p class="logo" aria-label="latama11y">
        <span class="brand-prefix">lata</span><span class="brand-m">m</span><span class="brand-suffix">a11y</span>
      </p>
      <p class="tagline">Accesibilidad digital · Digital accessibility</p>
    </div>

    <div class="divider" role="separator" aria-hidden="true"></div>

    <nav aria-label="Selección de idioma / Language selection">
      <div class="lang-options">
        <a
          href="/es/"
          class="lang-btn"
          lang="es"
          hreflang="es"
          onclick="saveLang('es')"
        >
          <span class="lang-btn__label">
            <span class="lang-btn__name">Ver en español</span>
            <span class="lang-btn__desc">Sitio completo en español</span>
          </span>
          <span class="lang-btn__arrow" aria-hidden="true">→</span>
        </a>

        <a
          href="/en/"
          class="lang-btn"
          lang="en"
          hreflang="en"
          onclick="saveLang('en')"
        >
          <span class="lang-btn__label">
            <span class="lang-btn__name">View in English</span>
            <span class="lang-btn__desc">Full site in English</span>
          </span>
          <span class="lang-btn__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </nav>
  </main>

  <script>
    // Si ya eligió idioma antes, redirigir directo
    const saved = localStorage.getItem('latama11y-lang');
    if (saved === 'es') {
      window.location.replace('/es/');
    } else if (saved === 'en') {
      window.location.replace('/en/');
    }

    function saveLang(lang) {
      localStorage.setItem('latama11y-lang', lang);
    }
  </script>
</body>
</html>
