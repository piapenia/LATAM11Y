---
// src/pages/en/index.astro
import Base from '../../layouts/Base.astro';
import Newsletter from '../../components/Newsletter.astro';
---

<Base
  lang="en"
  title="Digital accessibility consulting"
  description="latama11y — Specialized digital accessibility consulting for teams and products in Latin America."
>

  <!-- HERO -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container">
      <p class="hero-eyebrow" aria-hidden="true">// digital accessibility</p>
      <h1 id="hero-heading">
        We build technology<br />
        <span class="accent-gradient">that works for everyone.</span>
      </h1>
      <p class="hero-sub">
        Specialized digital accessibility consulting for product and development teams in Latin America.
        Audits, implementation, and technical guidance.
      </p>
      <div class="hero-actions">
        <a href="/en/services/" class="btn btn-primary">View services</a>
        <a href="/en/blog/" class="btn btn-ghost">Read research</a>
      </div>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true"></div>

  <!-- SERVICES PREVIEW -->
  <section class="services-preview" aria-labelledby="services-heading">
    <div class="container">
      <h2 id="services-heading" class="section-label">Services</h2>
      <ul class="services-grid" role="list">
        <li class="service-card">
          <p class="service-tag">01</p>
          <h3>Accessibility audit</h3>
          <p class="muted">Technical evaluation of websites and applications against WCAG 2.1 / 2.2. Detailed report with criteria, impact, and prioritized recommendations.</p>
        </li>
        <li class="service-card">
          <p class="service-tag">02</p>
          <h3>Technical consulting</h3>
          <p class="muted">Support for development teams to integrate accessibility into the design and product building process.</p>
        </li>
        <li class="service-card">
          <p class="service-tag">03</p>
          <h3>Component review</h3>
          <p class="muted">Analysis of design systems, component libraries, and critical flows to ensure accessibility from the ground up.</p>
        </li>
      </ul>
      <a href="/en/services/" class="link-more">View all services →</a>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true"></div>

  <!-- RESEARCH / BLOG PREVIEW -->
  <section class="blog-preview" aria-labelledby="blog-heading">
    <div class="container">
      <div class="blog-header">
        <h2 id="blog-heading" class="section-label">Research</h2>
        <a href="/en/blog/" class="link-more">View all →</a>
      </div>
      <p class="muted blog-sub">
        We analyze the accessibility of digital products across Latin America: government, banking, retail, transport.
        Country by country. No filters.
      </p>
      <div class="blog-placeholder" role="note">
        <p class="muted">First research pieces coming soon.</p>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <Newsletter lang="en" />

</Base>

<style>
  .hero { padding: var(--space-2xl) 0 var(--space-xl); }

  .hero-eyebrow {
    font-size: 0.8125rem;
    color: var(--color-purple-lt);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
    font-style: italic;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    max-width: 18ch;
    margin-bottom: var(--space-lg);
  }

  .accent-gradient {
    background: linear-gradient(135deg, var(--color-purple-lt) 0%, var(--color-pink) 50%, var(--color-red-lt) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    max-width: 52ch;
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .hero-actions { display: flex; gap: var(--space-md); flex-wrap: wrap; }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.75rem 1.5rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    display: inline-block;
  }

  .btn:focus-visible { outline: 2px solid var(--color-pink); outline-offset: 3px; }

  .btn-primary { background: var(--color-purple); color: #fff; border: 1px solid var(--color-purple); }
  .btn-primary:hover { background: #6d28d9; border-color: #6d28d9; color: #fff; text-decoration: none; }

  .btn-ghost { background: transparent; color: var(--color-muted); border: 1px solid var(--color-border); }
  .btn-ghost:hover { border-color: var(--color-purple-lt); color: var(--color-text); text-decoration: none; }

  .section-divider { height: 1px; background: var(--color-border); margin: var(--space-xl) 0; }

  .section-label {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 400;
    margin-bottom: var(--space-lg);
  }

  .services-preview { padding: var(--space-lg) 0; }

  .services-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .service-card { background: var(--color-bg); padding: var(--space-lg); transition: background 0.15s; }
  .service-card:hover { background: var(--color-surface); }
  .service-tag { font-size: 0.75rem; color: var(--color-purple-lt); font-family: var(--font-mono); margin-bottom: var(--space-md); }
  .service-card h3 { font-size: 1.0625rem; margin-bottom: var(--space-sm); }
  .service-card p { font-size: 0.875rem; line-height: 1.7; }
  .link-more { font-size: 0.875rem; color: var(--color-purple-lt); }
  .link-more:hover { color: var(--color-pink-lt); }

  .blog-preview { padding: var(--space-lg) 0; }
  .blog-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-sm); }
  .blog-sub { max-width: 58ch; font-size: 0.9375rem; margin-bottom: var(--space-lg); }
  .blog-placeholder { border: 1px dashed var(--color-border); padding: var(--space-lg); border-radius: 2px; }
  .blog-placeholder p { font-size: 0.875rem; }
</style>
